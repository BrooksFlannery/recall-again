{
  "name": "nextjs-effect-trpc-drizzle-boilerplate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.1.38",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "bun test",
    "vercel:env-pull": "bunx vercel env pull .env.local",
    "db:up": "docker compose up -d && drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx @better-auth/cli@latest generate --config src/server/auth.ts --output src/server/db/schema.ts --yes"
  },
  "dependencies": {
    "@effect/platform": "^0.69.0",
    "@tanstack/react-query": "^5.59.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.0.0",
    "dotenv": "^16.6.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "effect": "^3.11.0",
    "next": "^15.0.0",
    "openai": "^6.32.0",
    "pg": "^8.13.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.6.0"
  }
}
