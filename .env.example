# Database (PostgreSQL)
# Local: use Docker Compose (docker compose up -d), then run db:migrate
# Prod: set to your Neon (or other Postgres) connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recall_again

# Better Auth
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
