# Database (PostgreSQL)
# Local: use Docker Compose (docker compose up -d), then run db:migrate
# Prod: set to your Postgres connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recall_again

# Better Auth
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Public app URL (auth client, redirects). Set per environment: localhost in dev, canonical URL in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (create credentials in Google Cloud Console, add redirect URI)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI (question generation)
OPENAI_API_KEY=
OPENAI_QUESTION_MODEL=gpt-4o-mini
